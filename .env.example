# ── Resend (email delivery) ────────────────────────────────────────────────
# Sign up at https://resend.com, verify your domain, and create an API key.
# See lib/emails/templates.ts for full setup instructions.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for booking emails.
# Must be a verified sender on your Resend domain.
BOOKING_FROM_EMAIL=hello@truetodetail.co.uk

# ── Optional webhook (Zapier / Make / n8n) ────────────────────────────────
# If set, the full booking record is POSTed here as JSON after every booking.
BOOKING_WEBHOOK_URL=
